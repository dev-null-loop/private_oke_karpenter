security_lists = {
  svcs_lb = {
    vcn_name     = "vcn"
    display_name = "svcs_lb"
    egress_rules = [
      {
	description      = "SSH"
	destination      = "0.0.0.0/0"
	destination_type = "CIDR_BLOCK"
	protocol         = 6
	stateless        = false
      },
    ]
    ingress_rules = [
      {
	protocol    = "6"
	source      = "0.0.0.0/0"
	source_type = "CIDR_BLOCK"
	stateless   = false
	tcp_options = {
	  max = 443
	  min = 443
	}
      },
      {
	protocol    = "6"
	source      = "0.0.0.0/0"
	source_type = "CIDR_BLOCK"
	stateless   = false
	tcp_options = {
	  max = 80
	  min = 80
	}
      },
      {
	description = "SSH"
	protocol    = "6"
	source      = "0.0.0.0/0"
	source_type = "CIDR_BLOCK"
	stateless   = false
	tcp_options = {
	  max = 22
	  min = 22
	}
      },
      {
	description = "worker-nodes-to-native-ingress-controller"
	protocol    = "all"
	source      = "10.0.10.0/24"
	source_type = "CIDR_BLOCK"
	stateless   = false
      },
    ]
  },
  api_endpoint = {
    vcn_name     = "vcn"
    display_name = "api_endpoint"
    egress_rules = [
      {
	description      = "Allow Kubernetes Control Plane to communicate with OKE"
	destination      = "services"
	destination_type = "SERVICE_CIDR_BLOCK"
	protocol         = 6
	stateless        = false
	tcp_options = {
	  max = 443
	  min = 443
	}
      },
      {
	description      = "All traffic to worker nodes"
	destination      = "10.0.10.0/24"
	destination_type = "CIDR_BLOCK"
	protocol         = 6
	stateless        = false
      },
      {
	description      = "Path discovery"
	destination      = "10.0.10.0/24"
	destination_type = "CIDR_BLOCK"
	protocol         = 1
	stateless        = false
	icmp_options = {
	  code = 4,
	  type = 3
	}
      }
    ]
    ingress_rules = [
      {
	description = "External access to Kubernetes API endpoint"
	protocol    = "6"
	source      = "0.0.0.0/0"
	source_type = "CIDR_BLOCK"
	stateless   = false
	tcp_options = {
	  max = 6443
	  min = 6443
	}
      },
      {
	description = "Kubernetes worker to Kubernetes API endpoint communication"
	protocol    = "6"
	source      = "10.0.10.0/24"
	source_type = "CIDR_BLOCK"
	stateless   = false
	tcp_options = {
	  max = 6443
	  min = 6443
	}
      },
      {
	description = "Kubernetes worker to control plane communication"
	protocol    = "6"
	source      = "10.0.10.0/24"
	source_type = "CIDR_BLOCK"
	stateless   = false
	tcp_options = {
	  max = 12250
	  min = 12250
	}
      },
      {
	description = "Path discovery"
	protocol    = "1"
	source      = "10.0.10.0/24"
	source_type = "CIDR_BLOCK"
	stateless   = false
	icmp_options = {
	  code = 4
	  type = 3
	}
      }
    ]
  },
  nodes = {
    vcn_name     = "vcn"
    display_name = "nodes"
    egress_rules = [
      {
	description      = "Access to Kubernetes API Endpoint"
	destination      = "10.0.0.0/28"
	destination_type = "CIDR_BLOCK"
	protocol         = "6"
	stateless        = false
	tcp_options = {
	  max = 6443
	  min = 6443
	}
      },
      {
	description      = "Allow nodes to communicate with OKE to ensure correct start-up and continued functioning"
	destination      = "services"
	destination_type = "SERVICE_CIDR_BLOCK"
	protocol         = "6"
	stateless        = false
	tcp_options = {
	  max = 443
	  min = 443
	}
      },
      {
	description      = "Allow pods on one worker node to communicate with pods on other worker nodes"
	destination      = "10.0.10.0/24"
	destination_type = "CIDR_BLOCK"
	protocol         = "all"
	stateless        = false
      },
      {
	description      = "ICMP Access from Kubernetes Control Plane"
	destination      = "0.0.0.0/0"
	destination_type = "CIDR_BLOCK"
	protocol         = "1"
	stateless        = false
	icmp_options = {
	  code = 4
	  type = 3
	}
      },
      {
	description      = "Path discovery"
	destination      = "10.0.0.0/28"
	destination_type = "CIDR_BLOCK"
	protocol         = "1"
	stateless        = false
	icmp_options = {
	  code = 4
	  type = 3
	}
      },
      {
	description      = "Kubernetes worker to control plane communication"
	destination      = "10.0.0.0/28"
	destination_type = "CIDR_BLOCK"
	protocol         = "6"
	stateless        = false
	tcp_options = {
	  max = 12250
	  min = 12250
	}
      },
      {
	description      = "Worker Nodes access to Internet"
	destination      = "0.0.0.0/0"
	destination_type = "CIDR_BLOCK"
	protocol         = "all"
	stateless        = false
      },
      {
	description      = "native-ingress-controller"
	destination      = "10.0.20.0/24"
	destination_type = "CIDR_BLOCK"
	protocol         = "all"
	stateless        = false
      },

    ]
    ingress_rules = [
      {
	description = "Allow pods on one worker node to communicate with pods on other worker nodes"
	protocol    = "all"
	source      = "10.0.10.0/24"
	source_type = "CIDR_BLOCK"
	stateless   = false
      },
      {
	description = "Path discovery"
	protocol    = "1"
	source      = "10.0.0.0/28"
	source_type = "CIDR_BLOCK"
	stateless   = false
	icmp_options = {
	  code = 4
	  type = 3
	}
      },
      {
	description = "Inbound SSH traffic to worker nodes"
	protocol    = "6"
	source      = "0.0.0.0/0"
	source_type = "CIDR_BLOCK"
	stateless   = false
	tcp_options = {
	  max = 22
	  min = 22
	}
      },

      {
	description = "native-ingress-controller-80"
	protocol    = "6"
	source      = "10.0.20.0/24"
	source_type = "CIDR_BLOCK"
	stateless   = false
	tcp_options = {
	  max = 80
	  min = 80
	}
      },
      {
	description = "native-ingress-controller-443"
	protocol    = "6"
	source      = "10.0.20.0/24"
	source_type = "CIDR_BLOCK"
	stateless   = false
	tcp_options = {
	  max = 443
	  min = 443
	}
      },
      {
	description = "TCP access from Kubernetes Control Plane"
	protocol    = "6"
	source      = "10.0.0.0/28"
	source_type = "CIDR_BLOCK"
	stateless   = false
      }
    ]
  }
}
